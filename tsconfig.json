{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",        /* 编译输出目录 */
    "rootDir": "./src",         /* 源码存放目录 */
    "lib": ["ES2022"],
    "sourceMap": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]       /* 包含 src 目录下所有文件 */
}